*.swp
*.swo
# Emacs backup files
*~
# Sublime Text project files
*.sublime-project
*.sublime-workspace
# Atom editor files
.atom/

# Operating System files
# -------------------------------------------------------------

# macOS system files
.DS_Store
# Windows thumbnail cache
Thumbs.db
