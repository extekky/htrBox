global:
  resolve_timeout: 5m

route:
  receiver: telegram
  group_by:
    - alertname
    - instance
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

receivers:
  - name: telegram
{% if telegram_bot_token | length > 0 and telegram_chat_id | string | length > 0 %}
    telegram_configs:
      - bot_token: "{{ telegram_bot_token }}"
        chat_id: {{ telegram_chat_id }}
        parse_mode: HTML
        message: |-
          {% raw %}{{ range .Alerts }}
          <b>{{ .Status | toUpper }}: {{ .Labels.alertname }}</b>
          {{ .Annotations.summary }}
          instance={{ .Labels.instance }}
          severity={{ .Labels.severity }}
          {{ end }}{% endraw %}
{% else %}
    webhook_configs:
      - url: http://127.0.0.1:9/
        send_resolved: false
{% endif %}
