# Generated by Ansible from prod/infra/.env.
# Secret values are injected from GitHub Actions secrets.

# DATABASE
POSTGRES_DB=vpn
POSTGRES_USER=vpn
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# INITIAL ADMIN ACCOUNT
ADMIN_USERNAME={{ admin_username }}
ADMIN_PASSWORD={{ admin_password }}

# HYSTERIA SERVER MANAGEMENT API AUTH
HYSTERIA_AUTH={{ hysteria_auth }}
HYSTERIA_FETCH_PORT=8080

# JWT
JWT_SECRET={{ jwt_secret }}
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# COOKIE SETTINGS
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# CORS
ALLOWED_ORIGINS=http://localhost:80

# DEPLOYED IMAGE TAG
IMAGE_TAG={{ image_tag }}

# TRAFFIC COLLECTOR
TRAFFIC_POLL_INTERVAL=150
TRAFFIC_BUCKET_SECONDS=300

# MAINTENANCE WORKER
TRAFFIC_RETENTION_DAYS=7
MAINTENANCE_INTERVAL=3600

# RATE LIMITING
RT_MAX_FAILURES=10
RT_BLOCK_DURATION=10
RT_LOGIN_REQ=10
RT_LOGIN_WIN=60
RT_REFRESH_REQ=30
RT_REFRESH_WIN=60
RT_REGISTER_REQ=20
RT_REGISTER_WIN=60
RT_SERVERS_REQ=30
RT_SERVERS_WIN=60
RT_CHANGE_PASSWORD_REQ=20
RT_CHANGE_PASSWORD_WIN=300
RT_GENERATE_URL_REQ=30
RT_GENERATE_URL_WIN=60
RT_REGENERATE_HY_REQ=30
RT_REGENERATE_HY_WIN=60
RT_TRAFFIC_REQ=30
RT_TRAFFIC_WIN=60
RT_HEALTH_REQ=10
RT_HEALTH_WIN=60
RT_ME_REQ=30
RT_ME_WIN=60

# LOGGING
LOG_LEVEL=INFO

# API DOCUMENTATION
DOCS_ENABLED=false
