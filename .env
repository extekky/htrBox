# Environment Configuration

# ============================================================================
#                             DATABASE
# ============================================================================

# Postgres container credentials
POSTGRES_DB=htrbox # database name (can be anything)
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_HOST=postgres # service name in docker-compose.yaml

POSTGRES_PORT=5432  # if you change this, also update 
                    # the port mapping in docker-compose.yaml


# ============================================================================
#                      INITIAL ADMIN ACCOUNT (FIRST RUN ONLY)
# ============================================================================

# These credentials are used ONLY when:
#   -> the users table is empty
#   -> or all admin accounts have been deleted

# After initial creation these values are ignored.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin


# ============================================================================
#                   HYSTERIA SERVER MANAGEMENT API AUTH
# ============================================================================

# Secret used for backend <-> Hysteria server communication.
# You also need to change it in hysteria/config.yaml ->
HYSTERIA_AUTH=stasik

# Port on which the Hysteria server management API listens
HYSTERIA_FETCH_PORT=8080

# ============================================================================
#                             JWT (AUTHENTICATION)
# ============================================================================

# Secret key used to sign JWT tokens (critical security parameter)
# Recommendation: generate with `openssl rand -hex 32` or stronger
# Minimum length enforced: 32 characters
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_HEX_STRING

# JWT signing algorithm (HS256 / HS384 / HS512 supported)
JWT_ALGORITHM=HS256

# Access token lifetime
# Unit: minutes
JWT_ACCESS_TTL_MINUTES=30

# Refresh token lifetime
# Unit: days
JWT_REFRESH_TTL_DAYS=30


# ============================================================================
#                               COOKIE SETTINGS
# ============================================================================

# Whether cookies should be sent only over HTTPS
#   true  -> production (requires HTTPS)
#   false -> local development
COOKIE_SECURE=false

# Cookie SameSite attribute
#   strict -> most secure, but may break some cross-site flows
#   lax    -> balanced (recommended default)
#   none   -> required for cross-site usage (requires Secure=true)
COOKIE_SAMESITE=lax


# ============================================================================
#                               CORS
# ============================================================================

# Comma-separated list of allowed origins
# Never use wildcard "*" when credentials are involved
ALLOWED_ORIGINS=http://localhost:3000

# Example for production:
# ALLOWED_ORIGINS=https://panel.example.com,https://app.example.com


# ============================================================================
#                          TRAFFIC COLLECTOR
# ============================================================================

# How frequently the backend polls Hysteria servers for traffic data
# Unit: seconds
TRAFFIC_POLL_INTERVAL=150

# Time window for traffic aggregation / bucketing
# Unit: seconds | 300 = 5 minutes
TRAFFIC_BUCKET_SECONDS=300


# ============================================================================
#                          MAINTENANCE WORKER
# ============================================================================

# How long to keep 5-minute traffic buckets in traffic_5m
# Older rows are deleted by the maintenance worker
# Unit: days
TRAFFIC_RETENTION_DAYS=3

# How frequently the maintenance worker runs
# Handles: traffic_5m retention, expired refresh token cleanup
# Unit: seconds | 600 = 10 minutes
MAINTENANCE_INTERVAL=600


# ============================================================================
#                              RATE LIMITING
# ============================================================================

# These variables control per-endpoint rate limiting using sliding window.

# Global brute-force protection: max failed auth attempts per IP
RT_MAX_FAILURES=10

# Duration of temporary IP block after exceeding max failures
# Unit: seconds
RT_BLOCK_DURATION=10

# Per-endpoint rate limits (_REQ = max requests, _WIN = window in seconds)

# Login endpoint
RT_LOGIN_REQ=10
RT_LOGIN_WIN=60

# Refresh token endpoint
RT_REFRESH_REQ=30
RT_REFRESH_WIN=60

# User registration endpoint
RT_REGISTER_REQ=20
RT_REGISTER_WIN=60

# List servers endpoint
RT_SERVERS_REQ=30
RT_SERVERS_WIN=60

# Change password endpoint
RT_CHANGE_PASSWORD_REQ=20
RT_CHANGE_PASSWORD_WIN=300

# Generate access URL / client config
RT_GENERATE_URL_REQ=30
RT_GENERATE_URL_WIN=60

# Regenerate Hysteria credentials
RT_REGENERATE_HY_REQ=30
RT_REGENERATE_HY_WIN=60

# Get traffic statistics
RT_TRAFFIC_REQ=30
RT_TRAFFIC_WIN=60

# Health check endpoint
RT_HEALTH_REQ=10
RT_HEALTH_WIN=60

# Get current user info (/me)
RT_ME_REQ=30
RT_ME_WIN=60


# ============================================================================
#                                 LOGGING
# ============================================================================

# Logging level
#   DEBUG    -> detailed output (development)
#   INFO     -> normal operation (recommended for production)
#   WARNING  -> only warnings and above
#   ERROR    -> errors only
#   CRITICAL -> critical only
LOG_LEVEL=DEBUG


# ============================================================================
#                          API DOCUMENTATION
# ============================================================================

# Enable/disable interactive API documentation
#   /docs  -> Swagger UI
#   /redoc -> ReDoc
# Disable in production
DOCS_ENABLED=false